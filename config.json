    "webUIPort": 8222,
    "enableReportFile": true,
    "reportDirectory": "./reports",
    "reportFormat": "html"
  },
  "proxy": {
    "port": 9080,
    "streamLargeBodies": 10240
  },
  "privilegeEscalationScan": {
    "enabled": true,
    "similarityThreshold": 0.6,
    "paramPatterns": [
      "id=\\d+",
      "userId=\\d+",
      "user_id=\\d+",
      "memberId=\\d+",
      "member_id=\\d+",
      "accountId=\\d+",
      "account_id=\\d+",
      "orderId=\\d+",
      "order_id=\\d+",
      "tid=\\d+"
